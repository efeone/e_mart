 "font_size": 14,
 "html": "<style>\n@media print {\n    @page {\n        size: 38mm 25mm;\n        margin: 0;\n    }\n    body {\n        margin: 0;\n        padding: 0;\n    }\n    .barcode-label {\n        width: 38mm;\n        height: 25mm;\n        box-sizing: border-box;\n    }\n}\n</style>\n\n<div class=\"barcode-label\" style=\"\n    padding: 2px;\n    display: flex; \n    flex-direction: column; \n    justify-content: space-between;\n    font-family: Arial, sans-serif;\n\">\n    <div style=\"font-size:7px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;\">\n        E MART KITCHEN CARE\n    </div>\n    <div style=\"font-size:7px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;\">\n        {{ doc.item_name }}\n    </div>\n\n    {% if doc.barcodes and doc.barcodes[0].barcode %}\n    <div style=\"height:10mm; display:flex; align-items:center; justify-content:center;\">\n        <img class=\"barcode\" \n             style=\"max-width:100%; max-height:100%; object-fit:contain;\" \n             src=\"data:image/png;base64,{{ generate_barcodes(doc.barcodes[0].barcode) }}\">\n    </div>\n    <div style=\"text-align:center; font-size:7px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;\">\n        {{ doc.barcodes[0].barcode }}\n    </div>\n    {% endif %}\n\n    <div style=\"font-size:7px; white-space:nowrap; overflow:hidden;\">\n        MRP: \u20b9{{ doc.mrp or \"\" }}\n    </div>\n    <div style=\"font-size:8px; font-weight:bold; white-space:nowrap; overflow:hidden;\">\n        ERP: \u20b9{{ doc.valuation_rate or \"\" }}\n    </div>\n    <div style=\"font-size:6px; white-space:nowrap; overflow:hidden;\">\n        (incl. All Taxes)\n    </div>\n</div>\n",
